generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id        String   @id @default(uuid())
  name      String
  species   String
  breed     String?
  birthDate DateTime?
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("animals")
}
