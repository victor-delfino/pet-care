generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id        String   @id @default(uuid())
  name      String
  species   String
  breed     String?
  birthDate DateTime?
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vaccines  Vaccine[]
  vetVisits VetVisit[]
  feedings  Feeding[]
  reminders Reminder[]

  @@map("animals")
}

model Vaccine {
  id           String    @id @default(uuid())
  animalId     String
  name         String
  appliedAt    DateTime
  nextDoseAt   DateTime?
  veterinarian String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("vaccines")
}

model VetVisit {
  id           String   @id @default(uuid())
  animalId     String
  date         DateTime
  reason       String
  diagnosis    String?
  veterinarian String?
  cost         Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("vet_visits")
}

model Feeding {
  id        String   @id @default(uuid())
  animalId  String
  foodName  String
  frequency String
  quantity  String?
  time      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("feedings")
}

model Reminder {
  id          String   @id @default(uuid())
  animalId    String
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("reminders")
}
